APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# DB_ENGINE options: mariadb, mysql, postgresql, mssql
DB_ENGINE=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zkteco_sync
DB_USER=root
DB_PASSWORD=

# Only required when DB_ENGINE=mssql
# Common values:
#   ODBC Driver 17 for SQL Server
#   ODBC Driver 18 for SQL Server
#   SQL Server Native Client 11.0
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server
