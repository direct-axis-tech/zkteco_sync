APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

API_USERNAME=admin
API_PASSWORD=admin
# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# DB_ENGINE options: mariadb, mysql, postgresql, mssql
DB_ENGINE=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zkteco_sync
DB_USER=root
DB_PASSWORD=

# Only required when DB_ENGINE=mssql
# Common values:
#   ODBC Driver 17 for SQL Server
#   ODBC Driver 18 for SQL Server
#   SQL Server Native Client 11.0
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# MSSQL Windows Authentication: leave DB_USER and DB_PASSWORD both empty
# and the app will automatically use trusted_connection=yes (no credentials in URL)
